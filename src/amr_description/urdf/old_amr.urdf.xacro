<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="amr">

  <xacro:property name="body_length" value="0.50"/>
  <xacro:property name="body_width"  value="0.50"/>
  <xacro:property name="body_height" value="0.25"/>
  <xacro:property name="body_mass"   value="80.0"/>

  <xacro:property name="wheel_radius"     value="0.10"/>
  <xacro:property name="wheel_width"      value="0.05"/>
  <xacro:property name="wheel_mass"       value="3.0"/>
  <xacro:property name="wheel_separation" value="0.30"/>

  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${m/12*(y*y+z*z)}" ixy="0.0" ixz="0.0"
        iyy="${m/12*(x*x+z*z)}" iyz="0.0"
        izz="${m/12*(x*x+y*y)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia_y" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${m/12*(3*r*r+h*h)}" ixy="0.0" ixz="0.0"
        iyy="${m/2*r*r}"          iyz="0.0"
        izz="${m/12*(3*r*r+h*h)}"/>
    </inertial>
  </xacro:macro>

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${body_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 ${body_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${body_mass}" x="${body_length}" y="${body_width}" z="${body_height}"/>
  </link>

  <xacro:macro name="drive_wheel" params="name reflect">
    <link name="wheel_${name}_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia_y m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
    </link>
    <joint name="wheel_${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="wheel_${name}_link"/>
      <origin xyz="0 ${reflect * wheel_separation/2} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:drive_wheel name="left"  reflect=" 1"/>
  <xacro:drive_wheel name="right" reflect="-1"/>

  <xacro:property name="caster_radius" value="0.0635"/>
  <xacro:property name="caster_mass"   value="0.8"/>

  <xacro:macro name="sphere_inertia" params="m r">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${2/5*m*r*r}" ixy="0.0" ixz="0.0"
        iyy="${2/5*m*r*r}" iyz="0.0"
        izz="${2/5*m*r*r}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="caster_wheel" params="name xp yp">
    <link name="caster_${name}_link">
      <visual>
        <geometry><sphere radius="${caster_radius}"/></geometry>
        <material name="dark_grey"><color rgba="0.2 0.2 0.2 1.0"/></material>
      </visual>
      <collision>
        <geometry><sphere radius="${caster_radius}"/></geometry>
      </collision>
      <xacro:sphere_inertia m="${caster_mass}" r="${caster_radius}"/>
    </link>
    <joint name="caster_${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="caster_${name}_link"/>
      <origin xyz="${xp} ${yp} ${-wheel_radius+caster_radius+0.002}" rpy="0 0 0"/>
    </joint>

    <gazebo reference="caster_${name}_link">
      <mu1>0.0</mu1>
      <mu2>0.0</mu2>
      <material>Gazebo/DarkGrey</material>
    </gazebo>
  </xacro:macro>

  <xacro:caster_wheel name="front_left"  xp=" 0.20" yp=" 0.18"/>
  <xacro:caster_wheel name="front_right" xp=" 0.20" yp="-0.18"/>
  <xacro:caster_wheel name="mid_left"    xp=" 0.00" yp=" 0.23"/>
  <xacro:caster_wheel name="mid_right"   xp=" 0.00" yp="-0.23"/>
  <xacro:caster_wheel name="rear_left"   xp="-0.20" yp=" 0.18"/>
  <xacro:caster_wheel name="rear_right"  xp="-0.20" yp="-0.18"/>

  <gazebo reference="base_link">
    <material>Gazebo/Grey</material>
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <gazebo reference="wheel_left_link">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1><mu2>1.0</mu2>
    <kp>500000.0</kp><kd>10.0</kd>
    <minDepth>0.001</minDepth>
  </gazebo>
  
  <gazebo reference="wheel_right_link">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1><mu2>1.0</mu2>
    <kp>500000.0</kp><kd>10.0</kd>
    <minDepth>0.001</minDepth>
  </gazebo>
  
  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
      </ros>
      <left_joint>wheel_left_joint</left_joint>
      <right_joint>wheel_right_joint</right_joint>
      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheel_diameter>${2*wheel_radius}</wheel_diameter>
      
      <max_wheel_torque>50000.0</max_wheel_torque>
      <max_wheel_acceleration>10.0</max_wheel_acceleration>
      
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <publish_wheel_joint_state>true</publish_wheel_joint_state>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>
  </gazebo>

  <xacro:property name="lidar_x"    value="0.038"/>
  <xacro:property name="lidar_y"    value="0.038"/>
  <xacro:property name="lidar_z"    value="0.034"/>
  <xacro:property name="lidar_mass" value="0.10"/>

  <xacro:macro name="lidar_sensor" params="name xp yp yaw topic_name">
    <link name="${name}_link">
      <visual>
        <geometry><box size="${lidar_x} ${lidar_y} ${lidar_z}"/></geometry>
        <material name="blue"><color rgba="0.0 0.2 0.8 1.0"/></material>
      </visual>
      <collision>
        <geometry><box size="${lidar_x} ${lidar_y} ${lidar_z}"/></geometry>
      </collision>
      <inertial>
        <mass value="${lidar_mass}"/>
        <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
      </inertial>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="${name}_link"/>
      <origin xyz="${xp} ${yp} ${body_height}" rpy="0 0 ${yaw}"/>
    </joint>

    <gazebo reference="${name}_link">
      <material>Gazebo/Blue</material>
      <sensor name="${name}_sensor" type="ray">
        <always_on>true</always_on>
        <visualize>true</visualize> <update_rate>10</update_rate>    
        <ray>
          <scan>
            <horizontal>
              <samples>210</samples>
              <resolution>1</resolution>
              <min_angle>-1.8326</min_angle>
              <max_angle>1.8326</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.15</min> <max>12.0</max>
            <resolution>0.01</resolution>
          </range>
        </ray>
        <plugin name="${name}_plugin" filename="libgazebo_ros_ray_sensor.so">
          <ros><remapping>~/out:=${topic_name}</remapping></ros>
          <output_type>sensor_msgs/LaserScan</output_type>
          <frame_name>${name}_link</frame_name>
        </plugin>
      </sensor>
    </gazebo>
  </xacro:macro>

  <xacro:lidar_sensor name="lidar_front_right" xp=" 0.23" yp="-0.23" yaw="${-pi/4}" topic_name="scan_front"/>
  <xacro:lidar_sensor name="lidar_rear_left"   xp="-0.23" yp=" 0.23" yaw="${3*pi/4}" topic_name="scan_rear"/>

  <xacro:macro name="imu_sensor" params="name xp yp">
    <link name="${name}_link">
      <visual>
        <geometry><box size="0.025 0.025 0.005"/></geometry>
        <material name="green"><color rgba="0.0 0.8 0.0 1.0"/></material>
      </visual>
      <inertial>
        <mass value="0.02"/>
        <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
      </inertial>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="${name}_link"/>
      <origin xyz="${xp} ${yp} ${body_height-0.01}" rpy="0 0 0"/>
    </joint>

    <gazebo reference="${name}_link">
      <material>Gazebo/Green</material>
      <sensor name="${name}_sensor" type="imu">
        <always_on>true</always_on>
        <update_rate>50</update_rate>
        <plugin name="${name}_plugin" filename="libgazebo_ros_imu_sensor.so">
          <ros><remapping>~/out:=${name}/data</remapping></ros>
          <initial_orientation_as_reference>false</initial_orientation_as_reference>
        </plugin>
      </sensor>
    </gazebo>
  </xacro:macro>

  <xacro:imu_sensor name="imu_0" xp=" 0.10" yp="0.0"/>
  <xacro:imu_sensor name="imu_1" xp="-0.10" yp="0.0"/>

</robot>